            "date": 1763080667384,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Biblioteca | Willpig Studio</title>\n  <link rel=\"stylesheet\" href=\"/css/style1.2.css\" />\n  <link rel=\"icon\" href=\"/img/img.ico/logo.ico\">\n</head>\n<body>\n\n  <!-- ===== NAVBAR ===== -->\n  <header class=\"navbar\">\n    <div class=\"logo\" onclick=\"window.location.href='indexPrin.html'\">\n      <figure class=\"logo-fig\">\n        <img src=\"/img/img.ico/logo.ico\" alt=\"\">\n      </figure>\n      <span class=\"logo-text\"></span>\n    </div>\n\n    <input type=\"text\" class=\"search-bar\" placeholder=\"Buscar...\">\n\n    <div class=\"nav-actions\">\n      <!-- Escribir -->\n      <div class=\"dropdown\">\n        <div class=\"dropdown-trigger\">\n          <button class=\"dropbtn\">Escribir</button>\n          <img class=\"S1mMa\" src=\"/img/img.ico/wp-flecha- abajo.svg\" alt=\"flecha\">\n        </div>\n        <div class=\"dropdown-content\">\n          <a href=\"#\">Crea tu historia</a>\n          <a href=\"#\">Mis historias</a>\n        </div>\n      </div>\n\n      <!-- Explorar -->\n      <div class=\"dropdown\">\n        <div class=\"dropdown-trigger\">\n          <button class=\"dropbtn\">Explorar</button>\n          <img class=\"S1mMa\" src=\"/img/img.ico/wp-flecha- abajo.svg\" alt=\"flecha\">\n        </div>\n        <div class=\"dropdown-content\">\n          <a href=\"#\">Ficción</a>\n          <a href=\"#\">Fantasía</a>\n          <a href=\"#\">Historias cortas</a>\n          <a href=\"#\">Humor</a>\n          <a href=\"#\">Ciencia Ficción</a>\n          <a href=\"#\">Aventura</a>\n        </div>\n      </div>\n\n      <!-- Perfil -->\n      <div class=\"dropdown profile\">\n        <img src=\"https://img.wattpad.com/useravatar/dyrcorf.128.829516.jpg\" alt=\"dyrcorf\" class=\"avatar avatar-sm\">\n        <img class=\"S1mMa\" src=\"/img/img.ico/wp-flecha- abajo.svg\" alt=\"flecha\">\n        <div class=\"dropdown-content\">\n          <a href=\"#\">Mi perfil</a>\n          <a href=\"#\">Notificaciones</a>\n          <a href=\"#\">Biblioteca</a>\n          <a href=\"#\">Idioma: Español</a>\n          <a href=\"#\">Cerrar sesión</a>\n        </div>\n      </div>\n\n      <button class=\"theme-color\" id=\"theme-toggle\">🌙</button>\n    </div>\n  </header>\n\n  <!-- ===== BIBLIOTECA ===== -->\n  <section class=\"library-page\">\n    <div class=\"library-header\">\n      <h1>Biblioteca</h1>\n      <div class=\"library-tabs\">\n        <button class=\"tab-btn active\" data-tab=\"current-reads\">Lecturas actuales</button>\n        <button class=\"tab-btn\" data-tab=\"reading-lists\">Listas de lectura</button>\n      </div>\n    </div>\n\n    <div class=\"library-content\">\n      <!-- === Lecturas actuales === -->\n      <div id=\"current-reads\" class=\"tab-content active\">\n        <div class=\"section-title\">Todas las historias</div>\n\n        <div class=\"library-grid\">\n          <!-- Fila 1 -->\n          <div class=\"library-item\">\n            <img src=\"/img/Isla_R.jpg\" class=\"cover\" alt=\"El guardián del lago\">\n            <p class=\"title\">El guardián del lago</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@fabiwriter</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 3.1K\n            </div>\n          </div>\n\n          <div class=\"library-item\">\n            <img src=\"/img/Bosque_m.jpg\" class=\"cover\" alt=\"Vientos del Norte\">\n            <p class=\"title\">Vientos del Norte</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@ana_stories</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 2.9K\n            </div>\n          </div>\n\n          <div class=\"library-item\">\n            <img src=\"/img/Alicia.jpg\" class=\"cover\" alt=\"Corazones de Cristal\">\n            <p class=\"title\">Corazones de Cristal</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@valenart</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 5.8K\n            </div>\n          </div>\n\n          <div class=\"library-item\">\n            <img src=\"/img/la flor de otoño.jpg\" class=\"cover\" alt=\"Sombras del Pasado\">\n            <p class=\"title\">Sombras del Pasado</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@leo_writer</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 4.2K\n            </div>\n          </div>\n\n          <!-- Fila 2 -->\n          <div class=\"library-item\">\n            <img src=\"/img/adivina-cuanto-te-quiero.jpg\" class=\"cover\" alt=\"La Llama y la Flor\">\n            <p class=\"title\">La Llama y la Flor</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@camila_reads</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 1.7K\n            </div>\n          </div>\n\n          <div class=\"library-item\">\n            <img src=\"/img/debajo_de_la_luna.jpg\" class=\"cover\" alt=\"Hijos del Viento\">\n            <p class=\"title\">Hijos del Viento</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@david_writer</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 3.6K\n            </div>\n          </div>\n\n          <div class=\"library-item\">\n            <img src=\"/img/el pricipito.jpg\" class=\"cover\" alt=\"Puertas del Tiempo\">\n            <p class=\"title\">Puertas del Tiempo</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@isabel_art</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 6.2K\n            </div>\n          </div>\n\n          <div class=\"library-item\">\n            <img src=\"/img/cuentos cortos.jpg\" class=\"cover\" alt=\"Noche Eterna\">\n            <p class=\"title\">Noche Eterna</p>\n            <div class=\"author\">\n              <img src=\"/img/img.ico/user-icon.png\" alt=\"autor\">\n              <span>@nina_stories</span>\n            </div>\n            <div class=\"meta\">\n              <img src=\"/img/img.ico/eye.png\" alt=\"vistas\" class=\"icon-eye\"> 2.5K\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- === Listas de lectura === -->\n      <div id=\"reading-lists\" class=\"tab-content\">\n        <div class=\"section-title\">Tus listas de lectura</div>\n        <p>Aquí aparecerán tus listas personalizadas.</p>\n      </div>\n    </div>\n  </section>\n\n  <footer>\n    <div class=\"footer-links\">\n      <a href=\"#\">Willpig-Studio Originals</a>\n      <a href=\"#\">Términos</a>\n      <a href=\"#\">Privacidad</a>\n      <a href=\"#\">Ayuda</a>\n    </div>\n    <p>© 2025 Willpig Studio</p>\n  </footer>\n\n  <script>\n    // ==== Tabs funcionales ====\n    const tabs = document.querySelectorAll('.tab-btn');\n    const contents = document.querySelectorAll('.tab-content');\n\n    tabs.forEach(tab => {\n      tab.addEventListener('click', () => {\n        tabs.forEach(btn => btn.classList.remove('active'));\n        contents.forEach(content => content.classList.remove('active'));\n\n        tab.classList.add('active');\n        document.getElementById(tab.dataset.tab).classList.add('active');\n      });\n    });\n  </script>\n\n</body>\n</html>\n"
        }
    ]
}