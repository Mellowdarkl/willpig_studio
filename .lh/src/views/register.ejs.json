            "date": 1763332456957,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Registrarse | Willpig Studio</title>\n  <link rel=\"stylesheet\" href=\"/css/style1.2.css\" />\n  <link rel=\"icon\" href=\"/img/img.ico/logo.ico\">\n</head>\n<body>\n  <header class=\"Logps-navbar\">\n    <div class=\"logo-LTR\" onclick=\"window.location.href='index.html'\">\n    <figure class=\"logo-LTRA\">\n        <img src=\"/img/img.ico/LTRA.logo-resol.png\" alt=\"Willpig Studio Logo\">\n      </figure>\n      <span class=\"logo-text\"></span>\n    </div>\n  <div class=\"row\"></div>\n\n  <main class=\"register-container-igm\">\n    <div class=\"register-card\">\n      <h1>Crear una cuenta</h1>\n      <p>Únete a Willpig Studio y comparte tus historias ilustradas.</p>\n\n      <form action=\"/auth/register\" method=\"POST\" class=\"register-form\">\n        <div class=\"form-group\">\n          <label for=\"nombre\">Nombre</label>\n          <input type=\"text\" id=\"nombre\" name=\"nombre\" placeholder=\"Tu nombre\" required />\n        </div>\n        <div class=\"form-group\">\n          <label for=\"apellido\">Apellido</label>\n          <input type=\"text\" id=\"apellido\" name=\"apellido\" placeholder=\"Tu apellido\" required />\n        </div>\n        <div class=\"form-group\">\n          <label for=\"correo\">Correo electrónico</label>\n          <input type=\"email\" id=\"correo\" name=\"correo\" placeholder=\"ejemplo@email.com\" required />\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"contrasena\">Contraseña</label>\n          <input type=\"password\" id=\"contrasena\" name=\"contrasena\" placeholder=\"Crea una contraseña segura\" required />\n        </div>\n\n        <form action=\"/auth/register\" method=\"POST\">\n          <input type=\"text\" name=\"username\" />\n          <input type=\"password\" name=\"password\" />\n            <button type=\"submit\">Registrarse</button>\n        </form>\n\n        <button type=\"submit\" class=\"btn-register\">Registrarse</button>\n      </form>\n\n      <p class=\"login-link\">\n        ¿Ya tienes cuenta? <a href=\"/login\">Inicia sesión</a>\n      </p>\n    </div>\n  </main>\n\n    <footer>\n    <div class=\"footer-links\">\n      <a href=\"#\">Willpig-Studio Originals</a>\n      <a href=\"#\">Idioma</a>\n      <a href=\"#\">Escritores</a>\n      <a href=\"#\">Términos</a>\n      <li aria-hidden=\"true\" role=\"none\">|</li>\n      <a href=\"#\">Privacidad</a>\n      <a href=\"#\">Accesibilidad</a>\n      <a href=\"#\">Ayuda</a>\n    </div>\n    <p>© 2025 Willpig Studio</p>\n  </footer>\n</body>\n</html>\n"
        }
    ]
