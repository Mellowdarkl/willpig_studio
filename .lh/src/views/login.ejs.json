            "date": 1763342632698,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Iniciar sesión | Willpig Studio</title>\n  <link rel=\"stylesheet\" href=\"/css/style1.2.css\" />\n  <link rel=\"icon\" href=\"/img/img.ico/logo.ico\" />\n</head>\n<body>\n<span class=\"fa fa-image fa-wp-neutral-2 fa-3x\" aria-hidden=\"true\" style=\"font-size:60px;\"></span>\n<main class=\"loginIn-container\">\n    <div class=\"loginPin-card\">\n    <h1>Inicia sesión</h1>\n    <p>Bienvenido de nuevo a Willpig Studio</p>\n\n    <form action=\"/loginIni\" method=\"POST\" class=\"loginIN-form\">\n        <div class=\"formIN-group\">\n        <label for=\"correo\">Correo electrónico</label>\n        <input type=\"email\" id=\"correo\" name=\"correo\" placeholder=\"ejemplo@email.com\" required />\n        </div>\n\n        <div class=\"formIN-group\">\n        <label for=\"contrasena\">Contraseña</label>\n        <input type=\"password\" id=\"contrasena\" name=\"contrasena\" placeholder=\"Tu contraseña\" required />\n        </div>\n\n        <button type=\"submit\" class=\"btn-loginISi\">Iniciar sesión</button>\n    </form>\n\n    <div class=\"loginIN-links\">\n        <a href=\"#\" class=\"forgotvid-password\">¿Olvidaste tu contraseña?</a>\n        <p>¿No tienes cuenta? <a href=\"/register\">Regístrate aquí</a></p>\n    </div>\n    </div>\n</main>\n\n</body>\n</html>\n"
        }
    ]
