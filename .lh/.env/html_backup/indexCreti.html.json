            "date": 1762881357668,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Crear historia | Willpig Studio</title>\n  <link rel=\"stylesheet\" href=\"style1.2.css\" />\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"/public/img/img.ico/logo.ico\" />\n</head>\n<body>\n\n  <!-- 🧭 Barra superior -->\n  <header class=\"story-header\">\n    <div class=\"header-left\">\n      <a href=\"/\" class=\"back-link\">← Volver</a>\n      <h2>Agregar información de la historia</h2>\n    </div>\n\n    <div class=\"header-actions\">\n      <button class=\"btn-canceler\">Cancelar</button>\n      <button class=\"btn-savever\">Guardar</button>\n    </div>\n  </header>\n\n  <!--  Contenedor principal -->\n  <main class=\"new-storys\">\n    <!--  Lado izquierdo: portada -->\n    <div class=\"story-cover\">\n      <div class=\"cover-box\">\n        <img id=\"coverPreview\" src=\"/img/placeholder-cover.png\" alt=\"Portada\" />\n        <label for=\"coverInput\" class=\"btn-upload\">Añadir una portada</label>\n        <input type=\"file\" id=\"coverInput\" accept=\"image/*\" hidden>\n      </div>\n    </div>\n\n    <!--  Lado derecho: formulario -->\n    <form class=\"story-form\" action=\"/newstory\" method=\"POST\">\n      <section class=\"story-details\">\n        <h3>Detalles de la historia</h3>\n\n        <div class=\"form-group\">\n          <label for=\"titulo\">Título</label>\n          <input type=\"text\" id=\"titulo\" name=\"titulo\" placeholder=\"Historia sin título\" required>\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"descripcion\">Descripción</label>\n          <textarea id=\"descripcion\" name=\"descripcion\" placeholder=\"Describe brevemente tu historia...\"></textarea>\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"personajes\">Personajes principales</label>\n          <div class=\"inline-group\">\n            <input type=\"text\" id=\"personajes\" name=\"personajes\" placeholder=\"Nombre de personaje\">\n            <button type=\"button\" class=\"btn-add\">+</button>\n          </div>\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"categoria\">Categoría</label>\n          <select id=\"categoria\" name=\"categoria\">\n            <option value=\"\">Selecciona una categoría</option>\n            <option value=\"fantasia\">Fantasía</option>\n            <option value=\"romance\">Romance</option>\n            <option value=\"aventura\">Aventura</option>\n            <option value=\"drama\">Drama</option>\n            <option value=\"infantil\">Infantil</option>\n          </select>\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"etiquetas\">Etiquetas</label>\n          <input type=\"text\" id=\"etiquetas\" name=\"etiquetas\" placeholder=\"Agrega etiquetas separadas por comas\">\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"audiencia\">Audiencia principal</label>\n          <select id=\"audiencia\" name=\"audiencia\">\n            <option value=\"\">Selecciona una opción</option>\n            <option value=\"general\">General</option>\n            <option value=\"adolescentes\">Adolescentes</option>\n            <option value=\"adultos\">Adultos</option>\n          </select>\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"idioma\">Idioma</label>\n          <select id=\"idioma\" name=\"idioma\">\n            <option value=\"es\">Español</option>\n            <option value=\"en\">Inglés</option>\n          </select>\n        </div>\n\n        <div class=\"form-group\">\n          <label for=\"derechos\">Derechos de autor</label>\n          <select id=\"derechos\" name=\"derechos\">\n            <option value=\"todos\">Todos los derechos reservados</option>\n            <option value=\"compartido\">Uso compartido con créditos</option>\n            <option value=\"libre\">Dominio público</option>\n          </select>\n        </div>\n\n        <div class=\"form-group\">\n          <label>Clasificación</label>\n          <div class=\"inline-group\">\n            <label><input type=\"radio\" name=\"clasificacion\" value=\"todo\" checked> Todo público</label>\n            <label><input type=\"radio\" name=\"clasificacion\" value=\"maduro\"> Maduro</label>\n          </div>\n        </div>\n      </section>\n    </form>\n  </main>\n\n</body>\n</html>\n"
        }
