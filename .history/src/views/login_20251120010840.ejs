<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar sesión | Willpig Studio</title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="icon" href="/img/img.ico/logo.ico" />
</head>
<body>

<main class="loginIn-container">
    <div class="loginPin-card">
        <h1>Inicia sesión</h1>
        <p>Bienvenido de nuevo a Willpig Studio</p>

        <!-- FORMULARIO -->
        <form action="/loginIni" method="POST" class="form-login">

            <div class="form-group">
                <label for="correo">Correo electrónico</label>
                <input type="email" id="correo" name="correo"
                    placeholder="ejemplo@email.com" required />
            </div>

            <div class="form-group">
                <label for="contrasena">Contraseña</label>
                <input type="password" id="contrasena" name="contrasena"
                    placeholder="Tu contraseña" required />
            </div>

            <button type="submit" class="btn-login-pocket">Iniciar sesión</button>
        </form>

        <div class="login-links">
            <a href="#" class="forgot">¿Olvidaste tu contraseña?</a>
            <p>¿No tienes cuenta? <a href="/register">Regístrate aquí</a></p>
        </div>

        <% if (typeof error !== "undefined") { %>
            <p style="color:red; text-align:center;"><%= error %></p>
        <% } %>
    </div>
</main>

<footer>
    <div class="footer-links">
      <a href="#">Willpig-Studio Originals</a>
      <a href="#">Idioma</a>
      <a href="#">Ayuda</a>
      <a href="#">Términos de Servicio</a>
      <a href="#">Privacidad</a>
      <a href="#">Cookies</a>
      <a href="#">Información de anuncios</a>
      <a href="#">Más opciones...</a>
    </div>
    <p>&copy; 2024 Willpig Studio.</p>
</footer>

</body>
</html>
