<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar sesión | Willpig Studio</title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="icon" href="/img/img.ico/logo.ico" />
</head>

<body>

<!-- CONTENEDOR PRINCIPAL -->
<div class="login-pocketIN">

    <!-- LADO IZQUIERDO (IMAGEN) -->
    <div class="login-visual">
        <img src="/img/login-side.png" alt="Imagen Login">
    </div>

    <!-- LADO DERECHO (FORMULARIO) -->
    <div class="login-form-section">
        <div class="login-box">

            <h1>Inicia sesión</h1>
            <p>Bienvenido de nuevo a Willpig Studio</p>

            <!-- FORMULARIO -->
            <form action="/loginIni" method="POST" class="form-login">
                <div class="form-group">
                    <label for="correo">Correo electrónico</label>
                    <input type="email" id="correo" name="correo" required placeholder="ejemplo@correo.com">
                </div>

                <div class="form-group">
                    <label for="contrasena">Contraseña</label>
                    <input type="password" id="contrasena" name="contrasena" required placeholder="Tu contraseña">
                </div>

                <button type="submit" class="btn-login-pocket">Iniciar sesión</button>
            </form>

            <!-- ENLACES -->
            <a href="#" class="forgot">¿Olvidaste tu contraseña?</a>

            <div class="divider">O continúa con</div>

            <!-- BOTONES SOCIALES -->
            <div class="social-login">
                <button class="social-btn google">
                    <img src="/img/google.png" width="20"> Continuar con Google
                </button>
            </div>

            <p class="register-text">¿No tienes cuenta? <a href="/register">Regístrate aquí</a></p>

            <% if (typeof error !== "undefined") { %>
                <p style="color:rgb(214, 118, 118);"><%= error %></p>
            <% } %>

        </div>
    </div>
</div>

</body>
</html>
